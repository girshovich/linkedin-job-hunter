<%
// Minimal markdown → HTML: **bold**, line breaks into paragraphs
function renderMd(text) {
  if (!text) return '';
  // Escape HTML first
  let s = text
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;');
  // **bold**
  s = s.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
  // Split by blank lines into paragraphs, treat single newlines as <br>
  const paras = s.split(/\n{2,}/);
  return paras.map(p => '<p>' + p.replace(/\n/g, '<br>') + '</p>').join('');
}
%>
<%
function scoreTextColor(score) {
  if (score >= 85) return 'text-emerald-700 bg-emerald-50 border-emerald-200';
  if (score >= 71) return 'text-emerald-600 bg-emerald-50 border-emerald-200';
  return 'text-gray-600 bg-gray-100 border-gray-200';
}
const tz = (settings && settings.timezone) || 'UTC';
function formatDate(iso) {
  if (!iso) return '—';
  const d = new Date(iso);
  const date = d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric', timeZone: tz });
  const time = d.toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit', timeZone: tz });
  return `${date} ${time}`;
}
%>

<!-- Back link + Prev/Next nav -->
<div class="flex items-center justify-between mb-6 gap-4">
  <button onclick="history.back()" class="inline-flex items-center gap-1.5 text-sm text-gray-500 hover:text-gray-700 transition-colors flex-shrink-0">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
    <%= backLabel %>
  </button>
  <% if (prevId !== null || nextId !== null) { %>
  <div class="flex items-center gap-1">
    <% if (prevId !== null) { %>
    <a href="/job/<%= prevId %>?from=<%= from %>" id="nav-prev"
       class="inline-flex items-center gap-1.5 text-sm text-gray-500 hover:text-gray-700 px-3 py-1.5 rounded-lg hover:bg-gray-100 transition-colors" title="Previous (←)">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      Previous
    </a>
    <% } %>
    <% if (prevId !== null && nextId !== null) { %>
    <span class="text-gray-200 select-none">|</span>
    <% } %>
    <% if (nextId !== null) { %>
    <a href="/job/<%= nextId %>?from=<%= from %>" id="nav-next"
       class="inline-flex items-center gap-1.5 text-sm text-gray-500 hover:text-gray-700 px-3 py-1.5 rounded-lg hover:bg-gray-100 transition-colors" title="Next (→)">
      Next
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
    </a>
    <% } %>
  </div>
  <% } %>
</div>

<!-- Job header card -->
<div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 mb-6">
  <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4">
    <div class="flex-1 min-w-0">
      <!-- Badges -->
      <div class="flex items-center gap-2 flex-wrap mb-3">
        <% const detailVerdict = job.is_duplicate ? 'DUPLICATE' : job.ai_verdict; %>
        <button class="verdict-btn cursor-pointer" data-job-id="<%= job.id %>" data-verdict="<%= detailVerdict %>" data-chip-style="detail" title="Click to change status">
          <% if (detailVerdict === 'STRONG_MATCH') { %>
          <span class="px-2 py-0.5 rounded-full text-xs font-medium bg-emerald-100 text-emerald-700 border border-emerald-200">STRONG MATCH ▾</span>
          <% } else if (detailVerdict === 'WEAK_MATCH') { %>
          <span class="px-2 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-700 border border-yellow-200">WEAK MATCH ▾</span>
          <% } else if (detailVerdict === 'NO_MATCH') { %>
          <span class="px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-600 border border-red-200">NO MATCH ▾</span>
          <% } else if (detailVerdict === 'DUPLICATE') { %>
          <span class="px-2 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-600 border border-purple-200">DUPLICATE ▾</span>
          <% } %>
        </button>
        <% if (job.applied) { %>
        <span class="px-2 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-700 border border-blue-200">✓ Applied</span>
        <% } %>
      </div>

      <h1 class="text-xl font-bold text-gray-900 mb-1"><%= job.title %></h1>
      <p class="text-base text-gray-600 font-medium">
        <button id="company-name-btn" onclick="openCompanyNotePopover(event)"
                class="text-base text-gray-600 font-medium text-left"
                style="text-decoration:underline;text-decoration-style:dotted;text-underline-offset:3px;background:none;border:none;padding:0;cursor:pointer;">
          <%= job.company %>
        </button>
      </p>

      <div class="flex items-center gap-4 mt-3 flex-wrap text-sm text-gray-500">
        <% if (job.location) { %>
        <span class="flex items-center gap-1">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
          <%= job.location %>
        </span>
        <% } %>
        <% if (job.work_mode) { %>
        <span class="flex items-center gap-1 capitalize">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>
          <%= job.work_mode %>
        </span>
        <% } %>
        <% if (job.posted_date) { %>
        <span>Posted <%= new Date(job.posted_date).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric', timeZone: tz }) %></span>
        <% } %>
        <span class="text-gray-400">Fetched <%= formatDate(job.fetched_at) %></span>
      </div>
    </div>

    <!-- Score + actions -->
    <div class="flex flex-col gap-3 w-full md:w-auto">
      <div class="text-center">
        <div class="text-2xl md:text-4xl font-black score-badge <%= scoreTextColor(job.ai_score) %> px-3 py-2 md:px-5 md:py-3 rounded-xl border">
          <%= job.ai_score %>%
        </div>
        <p class="text-xs text-gray-400 mt-1">Relevance Score</p>
      </div>
      <% if (job.apply_url) { %>
      <a href="<%= job.apply_url %>" target="_blank"
         class="w-full inline-flex items-center justify-center gap-2 bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-medium px-4 py-2 rounded-lg transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
        Apply on Website
      </a>
      <% } %>
      <% if (job.url) { %>
      <a href="<%= job.url %>" target="_blank"
         class="w-full inline-flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium px-4 py-2 rounded-lg transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
        View on LinkedIn
      </a>
      <% } %>
      <!-- Applied toggle -->
      <% if (job.applied) { %>
      <button id="applied-btn" onclick="toggleApplied()"
              class="w-full inline-flex items-center justify-center gap-2 text-sm font-semibold px-4 py-2 rounded-lg border-2 transition-colors bg-emerald-600 border-emerald-600 text-white hover:bg-emerald-700">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
        Applied
      </button>
      <% } else { %>
      <button id="applied-btn" onclick="toggleApplied()"
              class="w-full inline-flex items-center justify-center gap-2 text-sm font-semibold px-4 py-2 rounded-lg border-2 transition-colors bg-white border-blue-400 text-blue-600 hover:bg-blue-50">
        Mark as Applied
      </button>
      <% } %>
      <!-- Compare to CV -->
      <button id="cv-compare-btn" onclick="openCvModal()"
              class="w-full inline-flex items-center justify-center gap-2 text-sm font-medium px-4 py-2 rounded-lg border border-gray-200 bg-gray-50 text-gray-600 hover:bg-gray-100 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
        Compare to CV
      </button>
    </div>
  </div>
</div>

<!-- Notes about the job -->
<div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 mb-6">
  <div class="flex items-center justify-between mb-3">
    <h2 class="text-base font-semibold text-gray-900">Notes about the job</h2>
    <button id="notes-save-btn" onclick="saveNotes()"
            class="text-xs font-medium text-blue-600 hover:text-blue-800 px-3 py-1 rounded-lg hover:bg-blue-50 transition-colors">
      Save
    </button>
  </div>
  <textarea id="notes-area" rows="3"
            placeholder="Add your notes about this job…"
            class="w-full rounded-lg border border-gray-200 px-3 py-2.5 text-sm text-gray-700 placeholder-gray-400 focus:ring-2 focus:ring-blue-500 focus:border-transparent resize-y"><%= job.user_notes || '' %></textarea>
  <p id="notes-status" class="text-xs text-gray-400 mt-1.5 hidden"></p>
</div>

<!-- Assessment against CV -->
<style>
  .cv-md { font-size: 0.875rem; line-height: 1.65; color: #1e3a5f; }
  .cv-md p { margin-top: 0.75em; margin-bottom: 0; }
  .cv-md p:first-child { margin-top: 0; }
  .cv-md strong { font-weight: 600; }
</style>
<% if (job.cv_assessment) { %>
<div id="cv-assessment-block" class="bg-blue-50 border border-blue-200 rounded-xl p-5 mb-6">
  <div class="flex items-center justify-between mb-3">
    <div class="flex items-center gap-2">
      <svg class="w-4 h-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
      <span class="text-sm font-semibold text-blue-800">In-Depth AI Assessment</span>
    </div>
    <button onclick="openCvModal()" class="text-xs text-blue-600 hover:text-blue-800 hover:underline">Re-run</button>
  </div>
  <div id="cv-assessment-text" class="cv-md"><%- renderMd(job.cv_assessment) %></div>
</div>
<% } else { %>
<div id="cv-assessment-block" class="hidden bg-blue-50 border border-blue-200 rounded-xl p-5 mb-6">
  <div class="flex items-center justify-between mb-3">
    <div class="flex items-center gap-2">
      <svg class="w-4 h-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
      <span class="text-sm font-semibold text-blue-800">In-Depth AI Assessment</span>
    </div>
    <button onclick="openCvModal()" class="text-xs text-blue-600 hover:text-blue-800 hover:underline">Re-run</button>
  </div>
  <div id="cv-assessment-text" class="cv-md"></div>
</div>
<% } %>

<!-- AI Rationale -->
<% if (job.ai_rationale) {
  const verdict = job.is_duplicate ? 'DUPLICATE' : job.ai_verdict;
  const rBox  = verdict === 'STRONG_MATCH' ? 'bg-emerald-50 border-emerald-200' : verdict === 'WEAK_MATCH' ? 'bg-yellow-50 border-yellow-200' : 'bg-red-50 border-red-200';
  const rIcon = verdict === 'STRONG_MATCH' ? 'text-emerald-600' : verdict === 'WEAK_MATCH' ? 'text-yellow-600' : 'text-red-500';
  const rHead = verdict === 'STRONG_MATCH' ? 'text-emerald-800' : verdict === 'WEAK_MATCH' ? 'text-yellow-800' : 'text-red-700';
  const rBody = verdict === 'STRONG_MATCH' ? 'text-emerald-900' : verdict === 'WEAK_MATCH' ? 'text-yellow-900' : 'text-red-800';
%>
<div class="<%= rBox %> border rounded-xl p-5 mb-6">
  <div class="flex items-center gap-2 mb-2">
    <svg class="w-4 h-4 <%= rIcon %>" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" /></svg>
    <span class="text-sm font-semibold <%= rHead %>">General AI Analysis</span>
  </div>
  <p class="text-sm <%= rBody %> leading-relaxed"><%= job.ai_rationale %></p>
</div>
<% } %>

<!-- Duplicate warning -->
<% if (job.is_duplicate && original) { %>
<div class="bg-purple-50 border border-purple-200 rounded-xl p-5 mb-6">
  <div class="flex items-center gap-2 mb-2">
    <svg class="w-4 h-4 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>
    <span class="text-sm font-semibold text-purple-800">Duplicate Detected</span>
  </div>
  <p class="text-sm text-purple-700">This job was flagged as a repost of an earlier listing.</p>
  <a href="/job/<%= original.id %>" class="inline-flex items-center gap-1 mt-2 text-sm text-purple-700 font-medium hover:underline">
    View original: <%= original.title %> →
  </a>
</div>
<% } %>

<!-- Duplicates of this job -->
<% if (duplicatesOfThis.length > 0) { %>
<div class="bg-gray-50 border border-gray-200 rounded-xl p-5 mb-6">
  <h3 class="text-sm font-semibold text-gray-700 mb-3">Reposts of this job (<%= duplicatesOfThis.length %>)</h3>
  <ul class="space-y-2">
    <% duplicatesOfThis.forEach(dup => { %>
    <li>
      <a href="/job/<%= dup.id %>" class="text-sm text-gray-600 hover:text-blue-600 hover:underline">
        <%= dup.title %> · <%= formatDate(dup.fetched_at) %>
      </a>
    </li>
    <% }); %>
  </ul>
</div>
<% } %>

<!-- Full description -->
<%
const _desc = job.description || '';
const _isHtml = /<[a-z][\s\S]*?>/i.test(_desc);
const _safeDesc = _isHtml
  ? (() => {
      // Security: strip scripts, styles, inline event handlers and inline styles
      let html = _desc
        .replace(/<script[\s\S]*?<\/script>/gi, '')
        .replace(/<style[\s\S]*?<\/style>/gi, '')
        .replace(/\son\w+="[^"]*"/gi, '')
        .replace(/style="[^"]*"/gi, '');

      if (!/<p\b/i.test(html)) {
        // Flat structure — Apify sometimes strips <p> tags and uses <br> as separators.
        // Convert any run of <br> into a paragraph break, then wrap the whole thing.
        html = '<p>' + html.replace(/(<br\s*\/?>\s*)+/gi, '</p><p>') + '</p>';
        // Split "<b>Header</b>content" → "<b>Header</b></p><p>content" so headers
        // get their own paragraph and the following text starts a fresh paragraph.
        html = html.replace(/(<p>)(<(?:b|strong)>[^<]{2,80}<\/(?:b|strong)>)/gi, '$1$2</p><p>');
      } else {
        // Block structure — clean up whitespace artifacts and split inline headers.
        html = html
          .replace(/<p>\s*(?:<br\s*\/?>\s*)*<\/p>/gi, '')
          .replace(/<p>(?:&nbsp;\s*)+<\/p>/gi, '')
          .replace(/([.!?;])\s*(<(?:strong|b)>[^<]{3,70}<\/(?:strong|b)>)/gi, '$1</p><p>$2');
      }

      // Remove empty paragraphs left by consecutive breaks or split artifacts
      return html.replace(/<p>(\s|&nbsp;)*<\/p>/gi, '');
    })()
  : null;
%>
<style>
  /* Scoped description styles — NO Tailwind prose class on this div to avoid conflicts. */
  .jd-html { font-size: 0.875rem; line-height: 1.6; color: #374151; }
  /* Every block-level element gets a 1em gap above it.
     margin-bottom stays 0 so gaps come entirely from margin-top (avoids double-spacing). */
  .jd-html p, .jd-html ul,
  .jd-html ol                            { margin-top: 1em; margin-bottom: 0; }
  .jd-html > *:first-child               { margin-top: 0; }
  .jd-html li                            { margin-top: 0.25em; margin-bottom: 0.25em; }
  /* Lists need indentation + markers since we dropped prose */
  .jd-html ul                            { padding-left: 1.5em; list-style-type: disc; }
  .jd-html ol                            { padding-left: 1.5em; list-style-type: decimal; }
  /* Real headings — bigger gap before, stick to what follows */
  .jd-html h1, .jd-html h2,
  .jd-html h3, .jd-html h4              { margin-top: 1.5em; margin-bottom: 0; font-weight: 600; }
  .jd-html h1 + *, .jd-html h2 + *,
  .jd-html h3 + *, .jd-html h4 + *     { margin-top: 0.25em; }
  /* Bold-only paragraphs (LinkedIn section headers) — bigger gap before, tight below */
  .jd-html p:has(> strong:only-child),
  .jd-html p:has(> b:only-child)        { margin-top: 1.5em; margin-bottom: 0; font-weight: 600; }
  .jd-html p:has(> strong:only-child) + *,
  .jd-html p:has(> b:only-child) + *   { margin-top: 0.25em; }
</style>
<div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
  <h2 class="text-base font-semibold text-gray-900 mb-4">Full Job Description</h2>
  <% if (_isHtml) { %>
  <div class="jd-html"><%- _safeDesc %></div>
  <% } else { %>
  <div class="prose prose-sm max-w-none text-gray-700 leading-relaxed whitespace-pre-wrap text-sm"><%= _desc %></div>
  <% } %>
</div>

<!-- Company note popover -->
<div id="company-note-popover" class="hidden fixed z-50 bg-white rounded-xl shadow-xl border border-gray-200 p-3" style="width:280px;max-width:90vw;">
  <div class="text-xs font-medium text-gray-500 mb-2">Company notes</div>
  <textarea id="company-note-popover-area" rows="4" maxlength="5000" placeholder="Add notes about this company…"
            class="w-full text-sm text-gray-700 border border-gray-200 rounded-lg p-2 resize-none focus:outline-none focus:border-blue-400"
            onkeydown="if(event.key==='Escape'){event.stopPropagation();closeCompanyNotePopover();}"></textarea>
  <div class="flex items-center justify-between mt-2">
    <span id="company-note-popover-status" class="text-xs text-emerald-600 hidden">✓ Saved</span>
    <button onclick="saveCompanyNotePopover()" class="text-xs bg-blue-600 text-white px-3 py-1 rounded-lg hover:bg-blue-700 transition-colors ml-auto">Save</button>
  </div>
</div>

<!-- CV Selection Modal -->
<div id="cv-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
  <div class="absolute inset-0 bg-black/40 backdrop-blur-sm" onclick="closeCvModal()"></div>
  <div class="relative bg-white rounded-2xl shadow-2xl w-full max-w-md">
    <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
      <h2 class="font-semibold text-gray-900">Compare to CV</h2>
      <button onclick="closeCvModal()" class="text-gray-400 hover:text-gray-600 p-1 rounded-lg hover:bg-gray-100 transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
    <div class="px-6 py-5">
      <% if (cvs && cvs.length > 0) { %>
      <p class="text-sm text-gray-600 mb-4">Select a CV to compare against this job:</p>
      <div class="space-y-2 mb-5">
        <% cvs.forEach(function(cv, i) { %>
        <label class="flex items-center gap-3 px-3 py-2.5 rounded-lg border border-gray-200 cursor-pointer hover:bg-gray-50 transition-colors has-[:checked]:border-blue-400 has-[:checked]:bg-blue-50">
          <input type="radio" name="cv_selection" value="<%= cv.id %>" <%= i === 0 ? 'checked' : '' %>
                 class="text-blue-600 focus:ring-blue-500" />
          <div class="min-w-0">
            <p class="text-sm font-medium text-gray-800 truncate"><%= cv.filename %></p>
            <p class="text-xs text-gray-400"><%= (cv.file_size / 1024).toFixed(0) %> KB · <%= new Date(cv.uploaded_at).toLocaleDateString('en-GB') %></p>
          </div>
        </label>
        <% }); %>
      </div>
      <div id="cv-modal-error" class="hidden text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg px-3 py-2 mb-3"></div>
      <button onclick="runCvCompare()"
              class="w-full inline-flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold px-4 py-2.5 rounded-lg transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
        <span id="cv-run-label">Analyse</span>
      </button>
      <% } else { %>
      <p class="text-sm text-gray-500 mb-4">No CVs uploaded yet. Go to <a href="/settings" class="text-blue-600 hover:underline">Settings</a> to upload a CV first.</p>
      <button onclick="closeCvModal()" class="w-full text-sm text-gray-600 bg-gray-100 hover:bg-gray-200 px-4 py-2 rounded-lg transition-colors">Close</button>
      <% } %>
    </div>
  </div>
</div>

<script>
const _jobId = <%= job.id %>;
const _companyName = <%- JSON.stringify(job.company) %>;

// Keyboard navigation: ← Previous, → Next
document.addEventListener('keydown', function(e) {
  if (e.target.tagName === 'TEXTAREA' || e.target.tagName === 'INPUT') return;
  if (e.key === 'ArrowLeft')  { const a = document.getElementById('nav-prev'); if (a) a.click(); }
  if (e.key === 'ArrowRight') { const a = document.getElementById('nav-next'); if (a) a.click(); }
});

let _applied = <%= job.applied ? 'true' : 'false' %>;
async function toggleApplied() {
  _applied = !_applied;
  const btn = document.getElementById('applied-btn');
  if (_applied) {
    btn.className = 'md:w-full inline-flex items-center justify-center gap-2 text-sm font-semibold px-4 py-2 rounded-lg border-2 transition-colors bg-emerald-600 border-emerald-600 text-white hover:bg-emerald-700';
    btn.innerHTML = '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>Applied';
  } else {
    btn.className = 'md:w-full inline-flex items-center justify-center gap-2 text-sm font-semibold px-4 py-2 rounded-lg border-2 transition-colors bg-white border-blue-400 text-blue-600 hover:bg-blue-50';
    btn.innerHTML = 'Mark as Applied';
  }
  await fetch('/api/jobs/' + _jobId + '/applied', {
    method: 'PATCH',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ applied: _applied }),
  }).catch(() => {});
}

function renderMdJs(text) {
  if (!text) return '';
  let s = text
    .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  s = s.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
  return text.split(/\n{2,}/).map(function(p) {
    let escaped = p.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    escaped = escaped.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
    return '<p>' + escaped.replace(/\n/g, '<br>') + '</p>';
  }).join('');
}

function openCvModal() {
  document.getElementById('cv-modal').classList.remove('hidden');
  document.getElementById('cv-modal-error')?.classList.add('hidden');
}

function closeCvModal() {
  document.getElementById('cv-modal').classList.add('hidden');
}

async function runCvCompare() {
  const selected = document.querySelector('input[name="cv_selection"]:checked');
  if (!selected) return;
  const cvId = selected.value;

  const label = document.getElementById('cv-run-label');
  const errEl = document.getElementById('cv-modal-error');
  label.textContent = 'Analysing…';

  try {
    const res = await fetch('/api/jobs/' + _jobId + '/cv-compare', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ cv_id: parseInt(cvId, 10) }),
    });
    const data = await res.json();
    if (data.ok) {
      const block = document.getElementById('cv-assessment-block');
      const text = document.getElementById('cv-assessment-text');
      text.innerHTML = renderMdJs(data.assessment);
      block.classList.remove('hidden');
      closeCvModal();
      block.scrollIntoView({ behavior: 'smooth', block: 'start' });
    } else {
      errEl.textContent = data.error || 'Analysis failed';
      errEl.classList.remove('hidden');
    }
  } catch {
    errEl.textContent = 'Network error — please try again';
    errEl.classList.remove('hidden');
  } finally {
    label.textContent = 'Analyse';
  }
}

let _companyPopoverOpen = false;
let _currentCompanyNote = <%- JSON.stringify(locals.companyNote || '') %>;

function closeCompanyNotePopover() {
  // Persist whatever is in the textarea as the current note
  const area = document.getElementById('company-note-popover-area');
  if (area) _currentCompanyNote = area.value;
  document.getElementById('company-note-popover').classList.add('hidden');
  _companyPopoverOpen = false;
}

function openCompanyNotePopover(event) {
  event.preventDefault();
  event.stopPropagation();
  const pop = document.getElementById('company-note-popover');
  if (_companyPopoverOpen) {
    closeCompanyNotePopover();
    return;
  }
  const area = document.getElementById('company-note-popover-area');
  area.value = _currentCompanyNote;
  document.getElementById('company-note-popover-status').classList.add('hidden');
  pop.classList.remove('hidden');
  _companyPopoverOpen = true;
  const btn = event.currentTarget;
  const rect = btn.getBoundingClientRect();
  const popW = 280, popH = 190;
  let left = rect.left;
  if (left + popW > window.innerWidth - 8) left = window.innerWidth - popW - 8;
  if (left < 8) left = 8;
  let top = rect.bottom + 6;
  if (top + popH > window.innerHeight - 8) top = rect.top - popH - 6;
  if (top < 8) top = 8;
  pop.style.left = left + 'px';
  pop.style.top = top + 'px';
  setTimeout(() => area.focus(), 50);
}

document.addEventListener('click', function(e) {
  if (!_companyPopoverOpen) return;
  const pop = document.getElementById('company-note-popover');
  const btn = document.getElementById('company-name-btn');
  if (!pop.contains(e.target) && !btn.contains(e.target)) {
    closeCompanyNotePopover();
  }
});

async function saveCompanyNotePopover() {
  const area = document.getElementById('company-note-popover-area');
  const note = area.value;
  const saveBtn = document.querySelector('#company-note-popover button');
  const status = document.getElementById('company-note-popover-status');
  saveBtn.textContent = 'Saving…';
  saveBtn.disabled = true;
  try {
    const res = await fetch('/api/company-notes', {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ company: _companyName, note }),
    });
    const data = await res.json();
    if (data.success) {
      _currentCompanyNote = note;
      closeCompanyNotePopover();
    } else {
      status.textContent = 'Error saving';
      status.className = 'text-xs text-red-500';
      status.classList.remove('hidden');
    }
  } catch {
    status.textContent = 'Error';
    status.className = 'text-xs text-red-500';
    status.classList.remove('hidden');
  } finally {
    saveBtn.textContent = 'Save';
    saveBtn.disabled = false;
  }
}

async function saveNotes() {
  const area = document.getElementById('notes-area');
  const notes = area.value;
  const btn = document.getElementById('notes-save-btn');
  const status = document.getElementById('notes-status');
  btn.textContent = 'Saving…';
  btn.disabled = true;
  try {
    const res = await fetch('/api/jobs/' + _jobId + '/notes', {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ notes }),
    });
    const data = await res.json();
    if (data.success) {
      status.textContent = '✓ Saved';
      status.className = 'text-xs mt-1.5 text-emerald-600';
      area.classList.add('border-emerald-300');
      // Hide status on next keystroke
      area.addEventListener('input', () => {
        status.classList.add('hidden');
        area.classList.remove('border-emerald-300');
      }, { once: true });
    } else {
      status.textContent = data.error || 'Error saving';
      status.className = 'text-xs mt-1.5 text-red-500';
    }
    status.classList.remove('hidden');
  } catch (e) {
    status.textContent = 'Network error';
    status.className = 'text-xs mt-1.5 text-red-500';
    status.classList.remove('hidden');
  } finally {
    btn.textContent = 'Save';
    btn.disabled = false;
  }
}
</script>
