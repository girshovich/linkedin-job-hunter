<%
function fmtDate(iso) {
  if (!iso) return { date: '—', time: '' };
  const d = new Date(String(iso));
  if (isNaN(d.getTime())) return { date: String(iso).slice(0, 10), time: '' };
  const offset = 4 * 60; // GMT+4 in minutes
  const local = new Date(d.getTime() + offset * 60_000);
  const date = local.toISOString().slice(0, 10);
  const time = local.toISOString().slice(11, 16);
  return { date, time };
}

function statusBadge(status) {
  if (status === 'success')       return 'bg-emerald-50 text-emerald-700';
  if (status === 'partial_error') return 'bg-amber-50 text-amber-700';
  if (status === 'running')       return 'bg-blue-50 text-blue-700';
  return 'bg-red-50 text-red-600';
}

function statusLabel(status) {
  if (status === 'partial_error') return 'partial error';
  return status;
}

function verdictChip(verdict, rejectionCategory) {
  if (verdict === 'STRONG_MATCH')
    return '<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-emerald-50 text-emerald-700 whitespace-nowrap">✅ Strong fit</span>';
  if (verdict === 'WEAK_MATCH')
    return '<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-amber-50 text-amber-700 whitespace-nowrap">⚠️ Weak fit</span>';
  if (verdict === 'BLACKLISTED')
    return '<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600 whitespace-nowrap">🚫 Blacklisted</span>';
  if (verdict === 'DUPLICATE')
    return '<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-purple-50 text-purple-600 whitespace-nowrap">🔁 Duplicate</span>';
  if (verdict === 'FILTERED')
    return '<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-slate-100 text-slate-500 whitespace-nowrap">✂ Filtered</span>';
  if (verdict === 'NO_MATCH') {
    if (rejectionCategory === 'NO_VISA')
      return '<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-red-50 text-red-600 whitespace-nowrap">❌ No visa support</span>';
    if (rejectionCategory === 'LANGUAGE_MISMATCH')
      return '<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-red-50 text-red-600 whitespace-nowrap">❌ Language mismatch</span>';
    if (rejectionCategory === 'PROFILE_MISMATCH')
      return '<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-red-50 text-red-600 whitespace-nowrap">❌ Profile mismatch</span>';
    return '<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-red-50 text-red-600 whitespace-nowrap">❌ No fit</span>';
  }
  return '';
}
%>

<!-- Page header -->
<div class="mb-8">
  <h1 class="text-2xl font-bold text-gray-900">Run Logs</h1>
  <p class="text-sm text-gray-500 mt-1">Full audit log of every pipeline run — showing last <%= runs.length %> run<%= runs.length !== 1 ? 's' : '' %> · <a href="/run-diff" class="text-blue-500 hover:underline">Compare</a> last 2 runs</p>
</div>

<% if (runs.length === 0) { %>
<div class="bg-white rounded-xl border border-gray-200 shadow-sm p-12 text-center">
  <svg class="w-10 h-10 text-gray-300 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
  </svg>
  <p class="text-sm text-gray-500">No pipeline runs yet. Run the pipeline from the Dashboard to see results here.</p>
</div>
<% } else { %>

<div class="space-y-3">
<% runs.forEach(run => {
  const dt = fmtDate(run.ran_at);
  const totalJobs = run.countryGroups.reduce((s, g) => s + g.jobs.length, 0);
%>

<details class="group bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
  <summary class="flex items-center justify-between px-5 py-4 cursor-pointer select-none list-none hover:bg-gray-50 transition-colors">
    <div class="flex items-center gap-3 flex-wrap min-w-0">
      <!-- Expand/collapse chevron -->
      <svg class="w-4 h-4 text-gray-400 flex-shrink-0 transition-transform group-open:rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>

      <!-- Date & time -->
      <div class="flex items-center gap-2">
        <span class="font-semibold text-gray-900 text-sm"><%= dt.date %></span>
        <span class="text-gray-400 text-xs">·</span>
        <span class="text-gray-500 text-sm"><%= dt.time %> GMT+4</span>
      </div>

      <!-- Status badge -->
      <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium capitalize <%= statusBadge(run.status) %>">
        <%= statusLabel(run.status) %>
      </span>

      <!-- Trigger badge -->
      <% if (run.trigger === 'manual') { %>
      <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-blue-50 text-blue-600">manual</span>
      <% } %>
    </div>

    <!-- Stats summary + cost button -->
    <div class="flex items-center gap-3 flex-shrink-0 ml-4">
      <span class="text-xs text-gray-500 hidden sm:block">
        <span class="font-medium text-gray-700"><%= run.jobs_fetched %></span> fetched
        · <span class="font-medium text-emerald-600"><%= run.jobs_strong_match %></span> strong
        · <span class="font-medium text-amber-600"><%= run.jobs_weak_match %></span> weak
        · <span class="font-medium text-red-500"><%= run.jobs_no_match %></span> no match
        · <span class="font-medium text-purple-600"><%= run.jobs_duplicate %></span> duplicates
        <% if (run.filteredCount > 0) { %>· <span class="font-medium text-slate-500"><%= run.filteredCount %></span> filtered<% } %>
        <% if (run.blacklistedCount > 0) { %>· <span class="font-medium text-gray-500"><%= run.blacklistedCount %></span> blacklisted<% } %>
      </span>
      <span class="text-xs text-gray-400"><%= totalJobs %> logged</span>

      <!-- Cost button -->
      <% if (run.cost_openai_usd != null || run.cost_apify_usd != null) { %>
      <div class="relative" onclick="event.stopPropagation()">
        <button
          onclick="toggleCostPopup('<%= run.id %>')"
          class="text-sm font-bold text-emerald-600 hover:text-emerald-700 w-7 h-7 flex items-center justify-center rounded-lg hover:bg-emerald-50 transition-colors"
          title="Run costs"
        >$</button>
        <div id="cost-popup-<%= run.id %>" class="hidden fixed z-50 bg-white border border-gray-200 rounded-xl shadow-lg p-3 text-xs min-w-[170px]">
          <% if (run.scraping_provider) { %>
          <div class="flex justify-between gap-6 text-gray-500 pb-1.5 mb-1.5 border-b border-gray-100">
            <span>Provider</span>
            <span class="font-medium text-gray-700"><%= run.scraping_provider === 'harvestapi' ? 'HarvestAPI' : run.scraping_provider.charAt(0).toUpperCase() + run.scraping_provider.slice(1) %></span>
          </div>
          <% } %>
          <% if (run.cost_openai_usd != null) { %>
          <div class="flex justify-between gap-6 text-gray-600">
            <span>OpenAI</span>
            <span class="font-medium text-gray-900">$<%= run.cost_openai_usd.toFixed(4) %></span>
          </div>
          <% } %>
          <% if (run.cost_apify_usd != null) { %>
          <div class="flex justify-between gap-6 text-gray-600 mt-1.5">
            <span>Apify</span>
            <span class="font-medium text-gray-900">$<%= run.cost_apify_usd.toFixed(4) %></span>
          </div>
          <% } %>
          <% if (run.cost_openai_usd != null && run.cost_apify_usd != null) { %>
          <div class="flex justify-between gap-6 mt-2 pt-2 border-t border-gray-100">
            <span class="font-medium text-gray-700">Total</span>
            <span class="font-bold text-gray-900">$<%= (run.cost_openai_usd + run.cost_apify_usd).toFixed(4) %></span>
          </div>
          <% } %>
        </div>
      </div>
      <% } %>
    </div>
  </summary>

  <!-- Expanded content -->
  <div class="border-t border-gray-100">

    <% if (run.error_log) { %>
    <div class="px-5 py-3 bg-red-50 border-b border-red-100">
      <p class="text-xs text-red-600 font-medium">Error log:</p>
      <pre class="text-xs text-red-500 mt-1 whitespace-pre-wrap"><%= run.error_log %></pre>
    </div>
    <% } %>

    <% if (run.countryGroups.length === 0) { %>
    <div class="px-5 py-8 text-center text-sm text-gray-400">
      No job logs for this run.
      <% if (run.status === 'running') { %>
      <span class="block mt-1 text-xs">Run is still in progress.</span>
      <% } %>
    </div>
    <% } else { %>

    <% run.countryGroups.forEach(group => { %>
    <div>
      <!-- Country header -->
      <div class="px-5 py-2.5 bg-gray-50 border-b border-gray-100 sticky top-0">
        <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wide"><%= group.country %></h3>
      </div>

      <!-- Job rows — desktop table -->
      <table class="hidden md:table w-full">
        <tbody class="divide-y divide-gray-50">
          <% group.jobs.forEach(job => {
            const jdt = fmtDate(job.logged_at);
          %>
          <tr class="hover:bg-gray-50 transition-colors">
            <td class="px-5 py-2.5 text-xs text-gray-400 whitespace-nowrap w-0">
              <span class="block"><%= jdt.date %></span>
              <span class="block text-gray-300"><%= jdt.time %></span>
            </td>
            <td class="px-3 py-2.5 text-sm text-gray-600 whitespace-nowrap w-0 max-w-[160px] truncate">
              <%= job.company %>
            </td>
            <td class="px-3 py-2.5 text-sm text-gray-900">
              <% if (job.internal_job_id) { %>
                <a href="/job/<%= job.internal_job_id %>" class="hover:text-blue-600 transition-colors"><%= job.title %></a>
              <% } else { %>
                <%= job.title %>
              <% } %>
            </td>
            <td class="px-3 py-2.5 text-xs w-0 whitespace-nowrap">
              <% if (job.url) { %>
                <a href="<%= job.url %>" target="_blank" rel="noopener noreferrer" class="text-blue-500 hover:underline">link</a>
              <% } else { %>
                <span class="text-gray-300">—</span>
              <% } %>
            </td>
            <td class="pl-3 pr-5 py-2.5 text-right w-0 whitespace-nowrap">
              <% if (job.internal_job_id || job.url) { %>
              <span onclick="showJobMenu(event,this)" data-internal-id="<%= job.internal_job_id || '' %>" data-url="<%= job.url || '' %>" class="cursor-pointer">
                <%- verdictChip(job.ai_verdict, job.rejection_category) %>
              </span>
              <% } else { %>
              <%- verdictChip(job.ai_verdict, job.rejection_category) %>
              <% } %>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>

      <!-- Job rows — mobile list -->
      <div class="md:hidden divide-y divide-gray-50">
        <% group.jobs.forEach(job => { %>
        <% const target = job.internal_job_id ? '/job/' + job.internal_job_id : (job.url || null); %>
        <div class="px-4 py-3 hover:bg-gray-50 transition-colors<%= target ? ' cursor-pointer' : '' %>"
             <% if (target) { %>onclick="location.href='<%= target %>'"<% } %>>
          <div class="flex items-center justify-between gap-2 mb-0.5">
            <span class="text-sm font-medium text-gray-700 truncate"><%= job.company %></span>
            <% if (job.internal_job_id || job.url) { %>
            <span onclick="showJobMenu(event,this)" data-internal-id="<%= job.internal_job_id || '' %>" data-url="<%= job.url || '' %>" class="cursor-pointer flex-shrink-0">
              <%- verdictChip(job.ai_verdict, job.rejection_category) %>
            </span>
            <% } else { %>
            <span class="flex-shrink-0"><%- verdictChip(job.ai_verdict, job.rejection_category) %></span>
            <% } %>
          </div>
          <p class="text-xs text-gray-500 truncate"><%= job.title %></p>
        </div>
        <% }); %>
      </div>
    </div>
    <% }); %>

    <% } %>

    <!-- Run footer -->
    <div class="px-5 py-2.5 border-t border-gray-100 text-xs text-gray-400 flex items-center justify-between">
      <span>Run #<%= run.id %></span>
      <% if (run.duration_ms) { %>
      <span><%= (run.duration_ms / 1000).toFixed(1) %>s</span>
      <% } %>
    </div>

  </div>
</details>

<% }); %>
</div>
<% } %>

<!-- Job context menu (shared) -->
<div id="job-menu" class="hidden fixed z-50 bg-white border border-gray-200 rounded-xl shadow-lg p-1.5 text-xs min-w-[140px]">
  <a id="job-menu-view" href="#" class="flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-gray-50 text-gray-700 transition-colors">View details</a>
  <a id="job-menu-link" href="#" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-gray-50 text-gray-700 transition-colors">Open on LinkedIn</a>
</div>

<script>
function showJobMenu(event, el) {
  event.stopPropagation();
  const internalId = el.dataset.internalId;
  const url = el.dataset.url;
  const menu = document.getElementById('job-menu');
  const viewLink = document.getElementById('job-menu-view');
  const extLink = document.getElementById('job-menu-link');

  if (internalId) {
    viewLink.href = '/job/' + internalId;
    viewLink.classList.remove('hidden');
  } else {
    viewLink.classList.add('hidden');
  }
  if (url) {
    extLink.href = url;
    extLink.classList.remove('hidden');
  } else {
    extLink.classList.add('hidden');
  }

  document.querySelectorAll('[id^="cost-popup-"]').forEach(el => el.classList.add('hidden'));
  const rect = el.getBoundingClientRect();
  menu.style.top = (rect.bottom + 4) + 'px';
  menu.style.left = Math.min(rect.left, window.innerWidth - 160) + 'px';
  menu.classList.remove('hidden');
}

function toggleCostPopup(runId) {
  const popup = document.getElementById('cost-popup-' + runId);
  const btn = popup.previousElementSibling;
  const isHidden = popup.classList.contains('hidden');
  document.querySelectorAll('[id^="cost-popup-"]').forEach(el => el.classList.add('hidden'));
  if (isHidden) {
    const rect = btn.getBoundingClientRect();
    popup.style.top = (rect.bottom + 4) + 'px';
    popup.style.right = (window.innerWidth - rect.right) + 'px';
    popup.classList.remove('hidden');
  }
}
document.addEventListener('click', () => {
  document.querySelectorAll('[id^="cost-popup-"]').forEach(el => el.classList.add('hidden'));
  document.getElementById('job-menu').classList.add('hidden');
});
</script>
