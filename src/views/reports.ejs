            <span>Apify</span>
            <span class="font-medium text-gray-900">$<%= run.cost_apify_usd.toFixed(4) %></span>
          </div>
          <% } %>
          <% if (run.cost_openai_usd != null && run.cost_apify_usd != null) { %>
          <div class="flex justify-between gap-6 mt-2 pt-2 border-t border-gray-100">
            <span class="font-medium text-gray-700">Total</span>
            <span class="font-bold text-gray-900">$<%= (run.cost_openai_usd + run.cost_apify_usd).toFixed(4) %></span>
          </div>
          <% } %>
        </div>
      </div>
      <% } %>
    </div>
  </summary>

  <!-- Expanded content -->
  <div class="border-t border-gray-100">

    <% if (run.error_log) { %>
    <div class="px-5 py-3 bg-red-50 border-b border-red-100">
      <p class="text-xs text-red-600 font-medium">Error log:</p>
      <pre class="text-xs text-red-500 mt-1 whitespace-pre-wrap"><%= run.error_log %></pre>
    </div>
    <% } %>

    <% if (run.countryGroups.length === 0) { %>
    <div class="px-5 py-8 text-center text-sm text-gray-400">
      No job logs for this run.
      <% if (run.status === 'running') { %>
      <span class="block mt-1 text-xs">Run is still in progress.</span>
      <% } %>
    </div>
    <% } else { %>

    <%
    const flatJobs = [];
    run.countryGroups.forEach(function(g) { flatJobs.push.apply(flatJobs, g.jobs); });
    flatJobs.sort(function(a, b) {
      const sa = a.ai_score, sb = b.ai_score;
      if (sa != null && sb != null) return sb - sa;
      if (sa != null) return -1;
      if (sb != null) return 1;
      const vp = { DUPLICATE: 0, BLACKLISTED: 1, FILTERED: 2 };
      return (vp[a.ai_verdict] || 99) - (vp[b.ai_verdict] || 99);
    });
