    <!-- Flat view: sorted by score (default) -->
    <div class="run-flat-view">
      <table class="hidden md:table w-full">
        <tbody class="divide-y divide-gray-50">
          <% flatJobs.forEach(function(job) { %>
          <tr class="hover:bg-gray-50 transition-colors">
            <td class="px-5 py-2.5 text-sm text-gray-600 whitespace-nowrap w-0 max-w-[160px] truncate">
              <%= job.company %>
            </td>
            <td class="px-3 py-2.5 text-sm text-gray-900">
              <% if (job.internal_job_id) { %>
                <a href="/job/<%= job.internal_job_id %>" class="hover:text-blue-600 transition-colors"><%= job.title %></a>
              <% } else { %>
                <%= job.title %>
              <% } %>
              <% if (job.location) { %><span class="block text-xs text-gray-400 truncate"><%= job.location %></span><% } %>
            </td>
            <td class="px-3 py-2.5 text-xs w-0 text-center whitespace-nowrap">
              <% if (job.ai_score != null) { %>
                <span class="<%= job.ai_score >= 71 ? 'text-emerald-600 font-semibold' : job.ai_score >= 51 ? 'text-amber-600 font-semibold' : 'text-red-500' %>"><%= job.ai_score %></span>
              <% } else { %>
                <span class="text-gray-300">—</span>
              <% } %>
            </td>
            <td class="px-3 py-2.5 text-xs w-0 whitespace-nowrap">
              <% if (job.url) { %>
                <a href="<%= job.url %>" target="_blank" rel="noopener noreferrer" class="text-blue-500 hover:underline">link</a>
              <% } else { %>
                <span class="text-gray-300">—</span>
              <% } %>
            </td>
            <td class="pl-3 pr-5 py-2.5 text-right w-0 whitespace-nowrap">
              <span onclick="showJobMenu(event,this)" data-internal-id="<%= job.internal_job_id || '' %>" data-url="<%= job.url || '' %>" data-log-id="<%= job.id %>" data-verdict="<%= job.ai_verdict %>" class="cursor-pointer">
                <%- verdictChip(job.ai_verdict, job.rejection_category) %>
