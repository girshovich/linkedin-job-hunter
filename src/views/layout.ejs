<!DOCTYPE html>
<html lang="en" class="h-full bg-gray-50">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Job Hunter — <%= title %></title>
  <link rel="icon" href="/icon.ico">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            brand: { 50: '#EFF6FF', 500: '#3B82F6', 600: '#2563EB', 700: '#1D4ED8' }
          }
        }
      }
    }
  </script>
  <style>
    [x-cloak] { display: none !important; }
    .score-badge { font-variant-numeric: tabular-nums; }
  </style>
</head>
<body class="h-full font-sans antialiased text-gray-900">

  <!-- Sidebar + content layout -->
  <div class="flex min-h-full">

    <!-- Sidebar (desktop only) -->
    <aside class="hidden md:flex w-56 flex-shrink-0 bg-gray-900 text-gray-100 flex-col sticky top-0 h-screen">

      <!-- Logo -->
      <div class="px-5 py-3 border-b border-gray-700">
        <div class="flex items-center gap-2">
          <div class="w-7 h-7 bg-blue-500 rounded-lg flex items-center justify-center text-white text-xs font-bold">JH</div>
          <span class="font-semibold text-sm text-white">Job Hunter</span>
        </div>
      </div>

      <!-- Profile Switcher -->
      <div class="px-3 py-2 border-b border-gray-700">
        <div class="flex rounded-lg overflow-hidden bg-gray-800 border border-gray-700 p-0.5 gap-0.5">
          <form method="POST" action="/api/profile/switch" class="flex-1">
            <input type="hidden" name="profile_id" value="1" />
            <button type="submit"
                    class="w-full text-xs font-semibold py-1.5 rounded-md transition-colors <%= activeProfile.id === 1 ? 'bg-white text-gray-900 shadow-sm' : 'text-gray-400 hover:text-gray-200' %>">
              Mikhail
            </button>
          </form>
          <form method="POST" action="/api/profile/switch" class="flex-1">
            <input type="hidden" name="profile_id" value="2" />
            <button type="submit"
                    class="w-full text-xs font-semibold py-1.5 rounded-md transition-colors <%= activeProfile.id === 2 ? 'bg-white text-gray-900 shadow-sm' : 'text-gray-400 hover:text-gray-200' %>">
              Arina
            </button>
          </form>
        </div>
      </div>

      <!-- Nav -->
      <nav class="flex-1 px-3 py-4 space-y-1 overflow-y-auto">
        <a href="/"
           class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium <%= title === 'Start' ? 'bg-white/10 text-white shadow-[inset_3px_0_0_rgba(255,255,255,0.55)]' : 'text-gray-400 hover:bg-white/5 hover:text-white' %> transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>
          Start
        </a>
        <a href="/jobs"
           class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium <%= title === 'Jobs Match' ? 'bg-white/10 text-white shadow-[inset_3px_0_0_rgba(255,255,255,0.55)]' : 'text-gray-400 hover:bg-white/5 hover:text-white' %> transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>
          Jobs Match
        </a>
        <a href="/history"
           class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium <%= title === 'Jobs All' ? 'bg-white/10 text-white shadow-[inset_3px_0_0_rgba(255,255,255,0.55)]' : 'text-gray-400 hover:bg-white/5 hover:text-white' %> transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" /></svg>
          Jobs All
        </a>
        <a href="/analytics"
           class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium <%= title === 'Stats' ? 'bg-white/10 text-white shadow-[inset_3px_0_0_rgba(255,255,255,0.55)]' : 'text-gray-400 hover:bg-white/5 hover:text-white' %> transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
          Stats
        </a>
        <a href="/reports"
           class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium <%= title === 'Run Logs' ? 'bg-white/10 text-white shadow-[inset_3px_0_0_rgba(255,255,255,0.55)]' : 'text-gray-400 hover:bg-white/5 hover:text-white' %> transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
          Run Logs
        </a>
        <a href="/settings"
           class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium <%= title === 'Settings' ? 'bg-white/10 text-white shadow-[inset_3px_0_0_rgba(255,255,255,0.55)]' : 'text-gray-400 hover:bg-white/5 hover:text-white' %> transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
          Settings
        </a>
      </nav>

      <!-- Bottom action buttons -->
      <div class="px-3 py-4 border-t border-gray-700 space-y-2">

        <!-- Run Once — opens confirmation modal -->
        <button id="sidebar-run-btn" onclick="openRunModal()"
                class="w-full flex items-center justify-center gap-2 px-3 py-2 bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-medium rounded-lg transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3l14 9-14 9V3z"/>
          </svg>
          <span id="sidebar-run-label">Run Once</span>
        </button>

        <!-- Schedule: inactive = blue config button, active = pulsing indicator + stop -->
        <div id="schedule-inactive">
          <button onclick="openScheduleModal()"
                  class="w-full flex items-center justify-center gap-2 px-3 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-lg transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            Schedule
          </button>
        </div>
        <div id="schedule-active" class="hidden space-y-1">
          <div class="flex items-center justify-between px-1">
            <span class="flex items-center gap-1.5 text-xs text-emerald-400 font-medium">
              <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse inline-block"></span>
              Schedule active
            </span>
            <span id="schedule-expr" class="text-xs text-gray-500 font-mono"></span>
          </div>
          <button onclick="scheduleStop()"
                  class="w-full flex items-center justify-center gap-2 px-3 py-2 bg-red-600 hover:bg-red-700 text-white text-sm font-medium rounded-lg transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 6h12v12H6z"/>
            </svg>
            Stop Schedule
          </button>
        </div>

        <p id="schedule-msg" class="text-xs text-gray-400 text-center hidden"></p>
      </div>
    </aside>

    <!-- Main content -->
    <main class="flex-1 overflow-y-auto">
      <div class="max-w-6xl mx-auto px-6 pt-8 pb-20 md:pb-8">
        <%- body %>
      </div>
    </main>
  </div>

  <!-- Bottom nav (mobile only) -->
  <nav class="md:hidden fixed bottom-0 left-0 right-0 z-40 bg-gray-900 border-t border-gray-700 flex items-stretch h-16 safe-area-inset-bottom">
    <a href="/" class="flex-1 flex flex-col items-center justify-center gap-0.5 <%= title === 'Start' ? 'text-white' : 'text-gray-400' %>">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>
      <span class="text-[10px] font-medium">Start</span>
    </a>
    <a href="/jobs" class="flex-1 flex flex-col items-center justify-center gap-0.5 <%= title === 'Jobs Match' ? 'text-white' : 'text-gray-400' %>">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>
      <span class="text-[10px] font-medium">Jobs</span>
    </a>
    <a href="/history" class="flex-1 flex flex-col items-center justify-center gap-0.5 <%= title === 'Jobs All' ? 'text-white' : 'text-gray-400' %>">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" /></svg>
      <span class="text-[10px] font-medium">All</span>
    </a>
    <a href="/reports" class="flex-1 flex flex-col items-center justify-center gap-0.5 <%= title === 'Run Logs' ? 'text-white' : 'text-gray-400' %>">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
      <span class="text-[10px] font-medium">Logs</span>
    </a>
    <a href="/settings" class="flex-1 flex flex-col items-center justify-center gap-0.5 <%= title === 'Settings' ? 'text-white' : 'text-gray-400' %>">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
      <span class="text-[10px] font-medium">Settings</span>
    </a>
    <button onclick="openProfileSheet()" class="flex-1 flex flex-col items-center justify-center gap-0.5">
      <div class="relative">
        <div class="w-7 h-7 rounded-full flex items-center justify-center text-white text-sm font-bold <%= activeProfile.id === 1 ? 'bg-blue-500' : 'bg-pink-400' %>">
          <%= activeProfile.id === 1 ? 'M' : 'A' %>
        </div>
        <span class="absolute bottom-0 right-0 w-2.5 h-2.5 rounded-full border-2 border-gray-900 <%= activeProfile.id === 1 ? 'bg-blue-400' : 'bg-pink-300' %>"></span>
      </div>
    </button>
  </nav>

  <!-- Profile bottom sheet (mobile only) -->
  <div id="profile-sheet" class="md:hidden hidden fixed inset-0 z-50">
    <div class="absolute inset-0 bg-black/50" onclick="closeProfileSheet()"></div>
    <div class="absolute bottom-16 left-0 right-0 bg-gray-900 rounded-t-2xl border-t border-gray-700 px-4 pt-4 pb-6">
      <p class="text-xs text-gray-500 font-semibold uppercase tracking-wider mb-3 px-1">Switch Profile</p>
      <form method="POST" action="/api/profile/switch">
        <input type="hidden" name="profile_id" value="1" />
        <button type="submit" class="w-full flex items-center gap-3 px-3 py-3 rounded-xl transition-colors <%= activeProfile.id === 1 ? 'bg-white/10 text-white' : 'text-gray-400 hover:bg-white/5' %>">
          <div class="w-8 h-8 rounded-full bg-blue-500 flex items-center justify-center text-white text-sm font-bold flex-shrink-0">M</div>
          <span class="font-medium text-sm">Mikhail</span>
          <% if (activeProfile.id === 1) { %>
          <svg class="w-4 h-4 text-emerald-400 ml-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
          <% } %>
        </button>
      </form>
      <form method="POST" action="/api/profile/switch">
        <input type="hidden" name="profile_id" value="2" />
        <button type="submit" class="w-full flex items-center gap-3 px-3 py-3 rounded-xl transition-colors <%= activeProfile.id === 2 ? 'bg-white/10 text-white' : 'text-gray-400 hover:bg-white/5' %>">
          <div class="w-8 h-8 rounded-full bg-pink-400 flex items-center justify-center text-white text-sm font-bold flex-shrink-0">A</div>
          <span class="font-medium text-sm">Arina</span>
          <% if (activeProfile.id === 2) { %>
          <svg class="w-4 h-4 text-emerald-400 ml-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
          <% } %>
        </button>
      </form>
      <div class="border-t border-gray-700 mt-3 pt-3 space-y-0.5">
        <a href="/analytics" class="flex items-center gap-3 px-3 py-2.5 rounded-xl <%= title === 'Stats' ? 'bg-white/10 text-white' : 'text-gray-400 hover:bg-white/5' %> transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
          <span class="text-sm font-medium">Stats</span>
        </a>
        <a href="/settings" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-gray-400 hover:bg-white/5 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
          <span class="text-sm font-medium">Settings</span>
        </a>
      </div>
    </div>
  </div>

  <!-- Confirm modal -->
  <div id="jh-confirm-modal" class="hidden fixed inset-0 z-[60] flex items-center justify-center p-4">
    <div class="absolute inset-0 bg-black/40 backdrop-blur-sm" onclick="_jhConfirmResolve(false)"></div>
    <div class="relative bg-white rounded-2xl shadow-2xl w-full max-w-sm overflow-hidden">
      <div class="px-6 py-5">
        <p id="jh-confirm-msg" class="text-sm text-gray-700 leading-relaxed"></p>
      </div>
      <div class="px-6 py-4 border-t border-gray-100 flex items-center justify-end gap-3">
        <button onclick="_jhConfirmResolve(false)"
                class="px-4 py-2 text-sm font-medium text-gray-600 hover:text-gray-800 hover:bg-gray-100 rounded-lg transition-colors">
          Cancel
        </button>
        <button onclick="_jhConfirmResolve(true)"
                class="px-4 py-2 text-sm font-semibold text-white bg-blue-600 hover:bg-blue-700 rounded-lg transition-colors">
          Confirm
        </button>
      </div>
    </div>
  </div>

  <!-- Alert modal -->
  <div id="jh-alert-modal" class="hidden fixed inset-0 z-[60] flex items-center justify-center p-4">
    <div class="absolute inset-0 bg-black/40 backdrop-blur-sm" onclick="_jhAlertResolve()"></div>
    <div class="relative bg-white rounded-2xl shadow-2xl w-full max-w-sm overflow-hidden">
      <div class="px-6 py-5">
        <p id="jh-alert-msg" class="text-sm text-gray-700 leading-relaxed"></p>
      </div>
      <div class="px-6 py-4 border-t border-gray-100 flex justify-end">
        <button onclick="_jhAlertResolve()"
                class="px-4 py-2 text-sm font-semibold text-white bg-blue-600 hover:bg-blue-700 rounded-lg transition-colors">
          OK
        </button>
      </div>
    </div>
  </div>

  <!-- Verdict dropdown -->
  <div id="verdict-dropdown" class="hidden fixed z-50 bg-white rounded-xl shadow-xl border border-gray-200 overflow-hidden" style="min-width:148px">
    <div class="py-1">
      <button onclick="setVerdict('STRONG_MATCH')" class="w-full text-left px-4 py-2 text-sm hover:bg-emerald-50 text-emerald-700 font-medium">✅ Strong fit</button>
      <button onclick="setVerdict('WEAK_MATCH')"   class="w-full text-left px-4 py-2 text-sm hover:bg-yellow-50 text-yellow-700 font-medium">⚠️ Weak fit</button>
      <button onclick="setVerdict('NO_MATCH')"     class="w-full text-left px-4 py-2 text-sm hover:bg-red-50 text-red-600 font-medium">❌ No fit</button>
      <button onclick="setVerdict('DUPLICATE')"    class="w-full text-left px-4 py-2 text-sm hover:bg-purple-50 text-purple-600 font-medium">🔁 Duplicate</button>
    </div>
  </div>

  <!-- Schedule Setup Modal -->
  <div id="schedule-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
    <div class="absolute inset-0 bg-black/40 backdrop-blur-sm" onclick="closeScheduleModal()"></div>
    <div class="relative bg-white rounded-2xl shadow-2xl w-full max-w-sm overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
        <h2 class="font-semibold text-gray-900">Run Schedule</h2>
        <button onclick="closeScheduleModal()" class="text-gray-400 hover:text-gray-600 p-1 rounded-lg hover:bg-gray-100 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
      <div class="px-6 py-4 space-y-4 max-h-[75vh] overflow-y-auto">
        <!-- Roles -->
        <div>
          <div class="text-sm font-medium text-gray-700 mb-2">Roles to run</div>
          <div id="sched-modal-groups" class="space-y-1 max-h-36 overflow-y-auto">
            <span class="text-sm text-gray-400">Loading…</span>
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Run at</label>
          <input id="sched-time-input" type="time" value="07:00"
                 class="w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:ring-2 focus:ring-blue-500" />
        </div>
        <!-- Frequency: daily vs specific days -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Frequency</label>
          <div class="flex gap-2 mb-2">
            <button type="button" id="freq-daily" onclick="setSchedFrequency('daily')"
                    class="freq-btn flex-1 py-1.5 px-3 rounded-lg border text-sm font-medium transition-colors">
              Daily
            </button>
            <button type="button" id="freq-custom" onclick="setSchedFrequency('custom')"
                    class="freq-btn flex-1 py-1.5 px-3 rounded-lg border text-sm font-medium transition-colors">
              Specific days
            </button>
          </div>
          <div id="sched-freq-days" class="hidden">
            <div class="flex flex-wrap gap-2">
              <label class="flex items-center gap-1.5 cursor-pointer text-sm text-gray-700 select-none">
                <input type="checkbox" class="sched-day-check w-3.5 h-3.5 accent-blue-600" value="1" checked> Mon
              </label>
              <label class="flex items-center gap-1.5 cursor-pointer text-sm text-gray-700 select-none">
                <input type="checkbox" class="sched-day-check w-3.5 h-3.5 accent-blue-600" value="2" checked> Tue
              </label>
              <label class="flex items-center gap-1.5 cursor-pointer text-sm text-gray-700 select-none">
                <input type="checkbox" class="sched-day-check w-3.5 h-3.5 accent-blue-600" value="3" checked> Wed
              </label>
              <label class="flex items-center gap-1.5 cursor-pointer text-sm text-gray-700 select-none">
                <input type="checkbox" class="sched-day-check w-3.5 h-3.5 accent-blue-600" value="4" checked> Thu
              </label>
              <label class="flex items-center gap-1.5 cursor-pointer text-sm text-gray-700 select-none">
                <input type="checkbox" class="sched-day-check w-3.5 h-3.5 accent-blue-600" value="5" checked> Fri
              </label>
              <label class="flex items-center gap-1.5 cursor-pointer text-sm text-gray-700 select-none">
                <input type="checkbox" class="sched-day-check w-3.5 h-3.5 accent-blue-600" value="6"> Sat
              </label>
              <label class="flex items-center gap-1.5 cursor-pointer text-sm text-gray-700 select-none">
                <input type="checkbox" class="sched-day-check w-3.5 h-3.5 accent-blue-600" value="0"> Sun
              </label>
            </div>
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Search period</label>
          <div class="flex gap-2">
            <button type="button" id="sched-dr-24h" onclick="setSchedDateRange('24h')"
                    class="sched-dr-btn flex-1 py-2 px-3 rounded-lg border text-sm font-medium transition-colors">
              Last 24h
            </button>
            <button type="button" id="sched-dr-7d" onclick="setSchedDateRange('7d')"
                    class="sched-dr-btn flex-1 py-2 px-3 rounded-lg border text-sm font-medium transition-colors">
              Last 7 days
            </button>
            <button type="button" id="sched-dr-month" onclick="setSchedDateRange('month')"
                    class="sched-dr-btn flex-1 py-2 px-3 rounded-lg border text-sm font-medium transition-colors">
              Month
            </button>
          </div>
        </div>
        <p id="sched-modal-msg" class="hidden text-xs"></p>
      </div>
      <div class="px-6 py-4 border-t border-gray-100 flex items-center justify-end gap-3">
        <button type="button" onclick="closeScheduleModal()"
                class="px-4 py-2 text-sm font-medium text-gray-600 hover:text-gray-800 hover:bg-gray-100 rounded-lg transition-colors">
          Cancel
        </button>
        <button id="sched-start-btn" onclick="startScheduleFromModal()"
                class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white font-semibold px-5 py-2 rounded-xl text-sm transition-colors shadow-sm">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          Start Schedule
        </button>
      </div>
    </div>
  </div>

  <!-- Schedule Status Modal (read-only, shown when schedule is active) -->
  <div id="schedule-status-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
    <div class="absolute inset-0 bg-black/40 backdrop-blur-sm" onclick="closeScheduleStatusModal()"></div>
    <div class="relative bg-white rounded-2xl shadow-2xl w-full max-w-sm overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
        <div class="flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse inline-block"></span>
          <h2 class="font-semibold text-gray-900">Schedule Active</h2>
        </div>
        <button onclick="closeScheduleStatusModal()" class="text-gray-400 hover:text-gray-600 p-1 rounded-lg hover:bg-gray-100 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
      <div class="px-6 py-5 space-y-3 text-sm">
        <div class="flex justify-between items-center">
          <span class="text-gray-500">Frequency</span>
          <span id="sched-status-freq" class="font-medium text-gray-900"></span>
        </div>
        <div class="flex justify-between items-center">
          <span class="text-gray-500">Runs at</span>
          <span id="sched-status-time" class="font-semibold font-mono text-gray-900"></span>
        </div>
        <div class="flex justify-between items-center">
          <span class="text-gray-500">Timezone</span>
          <span id="sched-status-tz" class="font-medium text-gray-900"></span>
        </div>
        <div class="flex justify-between items-center">
          <span class="text-gray-500">Search period</span>
          <span id="sched-status-dr" class="font-medium text-gray-900"></span>
        </div>
        <div class="flex justify-between items-center">
          <span class="text-gray-500">Roles</span>
          <span id="sched-status-roles" class="font-medium text-gray-900"></span>
        </div>
      </div>
      <div class="px-6 py-4 border-t border-gray-100 flex items-center justify-end gap-3">
        <button onclick="closeScheduleStatusModal()"
                class="px-4 py-2 text-sm font-medium text-gray-600 hover:text-gray-800 hover:bg-gray-100 rounded-lg transition-colors">
          Close
        </button>
        <button onclick="scheduleStop(); closeScheduleStatusModal();"
                class="inline-flex items-center gap-2 bg-red-600 hover:bg-red-700 text-white font-semibold px-5 py-2 rounded-xl text-sm transition-colors shadow-sm">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118zM9 10h6v4H9z"/>
          </svg>
          Stop Schedule
        </button>
      </div>
    </div>
  </div>

  <!-- Run Once Modal -->
  <div id="run-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
    <div class="absolute inset-0 bg-black/40 backdrop-blur-sm" onclick="closeRunModal()"></div>
    <div class="relative bg-white rounded-2xl shadow-2xl w-full max-w-sm overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
        <h2 class="font-semibold text-gray-900">Run Once</h2>
        <button onclick="closeRunModal()" class="text-gray-400 hover:text-gray-600 p-1 rounded-lg hover:bg-gray-100 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
      <div class="px-6 py-5 space-y-4">
        <!-- Roles -->
        <div>
          <div class="text-sm font-medium text-gray-700 mb-2">Roles to run</div>
          <div id="run-modal-groups" class="space-y-1 max-h-44 overflow-y-auto">
            <span class="text-sm text-gray-400">Loading…</span>
          </div>
        </div>
        <!-- Date range -->
        <div>
          <div class="text-sm font-medium text-gray-700 mb-2">Search period</div>
          <div class="flex gap-2 mb-2">
            <button type="button" id="run-dr-24h" onclick="setRunDateRange('24h')"
                    class="run-dr-btn flex-1 py-1.5 px-2 rounded-lg border text-sm font-medium transition-colors">
              Last 24h
            </button>
            <button type="button" id="run-dr-7d" onclick="setRunDateRange('7d')"
                    class="run-dr-btn flex-1 py-1.5 px-2 rounded-lg border text-sm font-medium transition-colors">
              Last 7 days
            </button>
            <button type="button" id="run-dr-month" onclick="setRunDateRange('month')"
                    class="run-dr-btn flex-1 py-1.5 px-2 rounded-lg border text-sm font-medium transition-colors">
              Month
            </button>
          </div>
        </div>
        <!-- Scraping provider -->
        <div>
          <div class="text-sm font-medium text-gray-700 mb-1.5">Scraping provider</div>
          <select id="run-provider-select" onchange="setRunProvider(this.value)"
                  class="w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:ring-2 focus:ring-blue-500 bg-white">
            <option value="harvestapi">HarvestAPI</option>
            <option value="valig">Valig</option>
          </select>
        </div>
        <p id="run-modal-msg" class="hidden text-xs text-red-600"></p>
      </div>
      <div class="px-6 py-4 border-t border-gray-100 flex items-center justify-end gap-3">
        <button type="button" onclick="closeRunModal()"
                class="px-4 py-2 text-sm font-medium text-gray-600 hover:text-gray-800 hover:bg-gray-100 rounded-lg transition-colors">
          Cancel
        </button>
        <button id="run-modal-submit" onclick="submitRun()"
                class="inline-flex items-center gap-2 bg-emerald-600 hover:bg-emerald-700 text-white font-semibold px-5 py-2 rounded-xl text-sm transition-colors shadow-sm">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          Run
        </button>
      </div>
    </div>
  </div>

  <script>
    // ---- Global state ----
    let _scheduleActive = false;
    let _scheduleData = null;   // latest data from /api/schedule/status
    let _schedDateRange = '24h';
    let _schedFrequency = 'daily';  // 'daily' | 'custom'
    let _runDateRange = '24h';
    let _runProvider = 'harvestapi';
    let _runCallback = null;    // set by home.ejs to handle progress display

    const DAY_NAMES = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];

    function escHtml(str) {
      return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    // ---- Schedule helpers ----

    function cronToLabel(expression, timezone) {
      if (!expression) return '';
      const parts = expression.split(' ');
      if (parts.length < 5) return expression;
      const h = String(parts[1]).padStart(2, '0');
      const m = String(parts[0]).padStart(2, '0');
      const tz = (timezone || 'UTC').split('/').pop().replace(/_/g, ' ');
      const dayPart = parts[4];
      const dayLabel = (!dayPart || dayPart === '*') ? '' : ' · ' + dayPart.split(',').map(d => DAY_NAMES[parseInt(d,10)] || d).join(', ');
      return h + ':' + m + ' ' + tz + dayLabel;
    }

    function getFrequencyLabel(expression) {
      if (!expression) return 'Daily';
      const parts = expression.split(' ');
      const dayPart = parts[4] || '*';
      if (dayPart === '*') return 'Daily';
      return dayPart.split(',').map(d => DAY_NAMES[parseInt(d,10)] || d).join(', ');
    }

    function setScheduleUI(active, expression, timezone) {
      _scheduleActive = active;
      document.getElementById('schedule-inactive').classList.toggle('hidden', active);
      document.getElementById('schedule-active').classList.toggle('hidden', !active);
      if (expression) document.getElementById('schedule-expr').textContent = cronToLabel(expression, timezone);

      // Sync home-page Schedule button if present
      const homeBtn = document.getElementById('home-schedule-btn');
      if (homeBtn) {
        const lbl = homeBtn.querySelector('[data-schedule-label]');
        if (active) {
          homeBtn.classList.remove('bg-blue-600', 'hover:bg-blue-700');
          homeBtn.classList.add('bg-emerald-600', 'hover:bg-emerald-700');
          if (lbl) lbl.textContent = 'Schedule ✓';
        } else {
          homeBtn.classList.remove('bg-emerald-600', 'hover:bg-emerald-700');
          homeBtn.classList.add('bg-blue-600', 'hover:bg-blue-700');
          if (lbl) lbl.textContent = 'Schedule';
        }
      }
    }

    function handleScheduleClick() {
      if (_scheduleActive) {
        openScheduleStatusModal();
      } else {
        openScheduleModal();
      }
    }

    function showScheduleMsg(text, isError) {
      const el = document.getElementById('schedule-msg');
      el.textContent = text;
      el.className = 'text-xs text-center mt-2 ' + (isError ? 'text-red-400' : 'text-gray-400');
      el.classList.remove('hidden');
      setTimeout(() => el.classList.add('hidden'), 4000);
    }

    // ---- Schedule Setup Modal ----

    function setSchedDateRange(range) {
      _schedDateRange = range;
      document.querySelectorAll('.sched-dr-btn').forEach(btn => {
        const isActive = btn.id === 'sched-dr-' + range;
        btn.classList.toggle('bg-blue-600', isActive);
        btn.classList.toggle('text-white', isActive);
        btn.classList.toggle('border-blue-600', isActive);
        btn.classList.toggle('text-gray-600', !isActive);
        btn.classList.toggle('border-gray-300', !isActive);
        btn.classList.toggle('hover:bg-gray-50', !isActive);
      });
    }

    function setSchedFrequency(freq) {
      _schedFrequency = freq;
      document.querySelectorAll('.freq-btn').forEach(btn => {
        const isActive = btn.id === 'freq-' + freq;
        btn.classList.toggle('bg-blue-600', isActive);
        btn.classList.toggle('text-white', isActive);
        btn.classList.toggle('border-blue-600', isActive);
        btn.classList.toggle('text-gray-600', !isActive);
        btn.classList.toggle('border-gray-300', !isActive);
        btn.classList.toggle('hover:bg-gray-50', !isActive);
      });
      document.getElementById('sched-freq-days')?.classList.toggle('hidden', freq !== 'custom');
    }

    function renderSchedGroups(groups) {
      const container = document.getElementById('sched-modal-groups');
      if (!groups || groups.length === 0) {
        container.innerHTML = '<span class="text-sm text-gray-400">No roles configured.</span>';
        return;
      }
      container.innerHTML = groups.map(g => {
        const on = !!g.is_active;
        return `
          <div class="flex items-center justify-between py-2 px-1">
            <span class="text-sm text-gray-800 flex-1">${escHtml(g.group_name || 'Role #' + g.id)}</span>
            <label class="flex items-center cursor-pointer">
              <input type="checkbox" class="sched-group-check sr-only" value="${g.id}"
                     ${on ? 'checked' : ''} onchange="onSchedGroupToggle(this)" />
              <div class="relative w-8 h-4 rounded-full transition-colors ${on ? 'bg-emerald-500' : 'bg-gray-300'}">
                <div class="absolute top-0.5 ${on ? 'left-4' : 'left-0.5'} w-3 h-3 bg-white rounded-full shadow transition-all"></div>
              </div>
            </label>
          </div>`;
      }).join('');
    }

    function onSchedGroupToggle(checkbox) {
      const track = checkbox.nextElementSibling;
      const thumb = track.firstElementChild;
      if (checkbox.checked) {
        track.classList.replace('bg-gray-300', 'bg-emerald-500');
        thumb.classList.replace('left-0.5', 'left-4');
      } else {
        track.classList.replace('bg-emerald-500', 'bg-gray-300');
        thumb.classList.replace('left-4', 'left-0.5');
      }
    }

    function openScheduleModal() {
      document.getElementById('sched-modal-groups').innerHTML = '<span class="text-sm text-gray-400">Loading…</span>';
      document.getElementById('sched-modal-msg').classList.add('hidden');
      document.getElementById('sched-start-btn').disabled = false;
      document.getElementById('sched-start-btn').innerHTML = '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>Start Schedule';
      document.getElementById('schedule-modal').classList.remove('hidden');

      fetch('/api/schedule/status').then(r => r.json()).then(data => {
        _scheduleData = data;
        if (data.email_send_time) document.getElementById('sched-time-input').value = data.email_send_time;
        setSchedDateRange(data.schedule_date_range || '24h');

        // Pre-fill frequency + days from saved cron expression
        const expr = data.expression || '';
        const parts = expr.split(' ');
        const dayPart = parts[4] || '*';
        if (!dayPart || dayPart === '*') {
          setSchedFrequency('daily');
        } else {
          setSchedFrequency('custom');
          const selectedDays = dayPart.split(',').map(d => parseInt(d, 10));
          document.querySelectorAll('.sched-day-check').forEach(cb => {
            cb.checked = selectedDays.includes(parseInt(cb.value, 10));
          });
        }

        // Render groups using is_active state
        renderSchedGroups(data.groups || []);
      }).catch(() => {
        setSchedDateRange('24h');
        setSchedFrequency('daily');
        document.getElementById('sched-modal-groups').innerHTML = '<span class="text-sm text-red-500">Failed to load roles.</span>';
      });
    }

    function closeScheduleModal() {
      document.getElementById('schedule-modal').classList.add('hidden');
    }

    async function startScheduleFromModal() {
      const time = document.getElementById('sched-time-input').value;
      const timezone = (_scheduleData && _scheduleData.timezone) || 'UTC';
      const btn = document.getElementById('sched-start-btn');
      const msgEl = document.getElementById('sched-modal-msg');

      // Validate days selection
      let scheduleDays = '*';
      if (_schedFrequency === 'custom') {
        const checked = Array.from(document.querySelectorAll('.sched-day-check:checked')).map(c => c.value);
        if (checked.length === 0) {
          msgEl.textContent = 'Select at least one day.';
          msgEl.className = 'text-xs text-red-600';
          msgEl.classList.remove('hidden');
          return;
        }
        scheduleDays = checked.sort((a, b) => parseInt(a) - parseInt(b)).join(',');
      }

      // Collect all toggle states
      const allSchedToggles = document.querySelectorAll('.sched-group-check');
      const schedGroupStates = Array.from(allSchedToggles).map(c => ({
        id: parseInt(c.value, 10),
        is_active: c.checked,
      }));

      btn.disabled = true;
      btn.textContent = 'Starting…';
      msgEl.classList.add('hidden');

      try {
        // Sync is_active states with Settings and Run Once
        await Promise.all(schedGroupStates.map(({ id, is_active }) =>
          fetch('/api/groups/' + id, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ is_active }),
          })
        ));

        const res = await fetch('/api/schedule/start', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            email_send_time: time,
            timezone,
            schedule_date_range: _schedDateRange,
            schedule_days: scheduleDays,
          }),
        });
        const data = await res.json();
        if (data.success) {
          _scheduleData = data;
          setScheduleUI(true, data.expression, data.timezone);
          showScheduleMsg('Schedule started', false);
          closeScheduleModal();
        } else {
          msgEl.textContent = data.error || 'Error starting schedule';
          msgEl.className = 'text-xs text-red-600';
          msgEl.classList.remove('hidden');
          btn.disabled = false;
          btn.innerHTML = '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>Start Schedule';
        }
      } catch (e) {
        msgEl.textContent = 'Network error';
        msgEl.className = 'text-xs text-red-600';
        msgEl.classList.remove('hidden');
        btn.disabled = false;
        btn.innerHTML = '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>Start Schedule';
      }
    }

    async function scheduleStop() {
      try {
        const res = await fetch('/api/schedule/stop', { method: 'POST' });
        const data = await res.json();
        if (data.success) {
          setScheduleUI(false, null, null);
          showScheduleMsg('Schedule stopped', false);
        }
      } catch (e) {
        showScheduleMsg('Network error', true);
      }
    }

    // ---- Schedule Status Modal ----

    function openScheduleStatusModal() {
      if (_scheduleData) {
        const tz = _scheduleData.timezone || '';
        const expr = _scheduleData.expression || '';
        const dr = _scheduleData.schedule_date_range || '24h';
        const groups = _scheduleData.groups || [];
        const groupIds = _scheduleData.schedule_group_ids || [];

        // Time from cron expression
        const parts = expr.split(' ');
        const h = String(parts[1] || '7').padStart(2, '0');
        const m = String(parts[0] || '0').padStart(2, '0');
        document.getElementById('sched-status-time').textContent = h + ':' + m;
        document.getElementById('sched-status-tz').textContent = tz.split('/').pop()?.replace(/_/g, ' ') || tz;
        document.getElementById('sched-status-dr').textContent = dr === '7d' ? 'Last 7 days' : 'Last 24h';
        document.getElementById('sched-status-freq').textContent = getFrequencyLabel(expr);

        // Roles display
        if (groupIds.length === 0) {
          document.getElementById('sched-status-roles').textContent = 'All active';
        } else {
          const selectedNames = groups.filter(g => groupIds.includes(g.id)).map(g => g.group_name || 'Role #' + g.id);
          const activeCount = groups.filter(g => g.is_active).length;
          if (selectedNames.length === activeCount && activeCount > 0) {
            document.getElementById('sched-status-roles').textContent = 'All active';
          } else {
            document.getElementById('sched-status-roles').textContent = groupIds.length + ' of ' + groups.length + ' roles';
          }
        }
      }
      document.getElementById('schedule-status-modal').classList.remove('hidden');
    }

    function closeScheduleStatusModal() {
      document.getElementById('schedule-status-modal').classList.add('hidden');
    }

    // ---- Run Once Modal ----

    function setRunDateRange(range) {
      _runDateRange = range;
      document.querySelectorAll('.run-dr-btn').forEach(btn => {
        const isActive = btn.id === 'run-dr-' + range;
        btn.classList.toggle('bg-blue-600', isActive);
        btn.classList.toggle('text-white', isActive);
        btn.classList.toggle('border-blue-600', isActive);
        btn.classList.toggle('text-gray-600', !isActive);
        btn.classList.toggle('border-gray-300', !isActive);
        btn.classList.toggle('hover:bg-gray-50', !isActive);
      });
    }

    function setRunProvider(provider) {
      _runProvider = provider;
      const sel = document.getElementById('run-provider-select');
      if (sel && sel.value !== provider) sel.value = provider;
    }

    function renderRunGroups(groups) {
      const container = document.getElementById('run-modal-groups');
      if (!groups || groups.length === 0) {
        container.innerHTML = '<span class="text-sm text-gray-400">No roles configured.</span>';
        return;
      }
      container.innerHTML = groups.map(g => {
        const on = !!g.is_active;
        return `
          <div class="flex items-center justify-between py-2 px-1">
            <span class="text-sm text-gray-800">${escHtml(g.group_name || 'Role #' + g.id)}</span>
            <label class="flex items-center cursor-pointer">
              <input type="checkbox" class="run-group-check sr-only" value="${g.id}"
                     ${on ? 'checked' : ''} onchange="onRunGroupToggle(this)" />
              <div class="relative w-8 h-4 rounded-full transition-colors ${on ? 'bg-emerald-500' : 'bg-gray-300'}">
                <div class="absolute top-0.5 ${on ? 'left-4' : 'left-0.5'} w-3 h-3 bg-white rounded-full shadow transition-all"></div>
              </div>
            </label>
          </div>`;
      }).join('');
    }

    function onRunGroupToggle(checkbox) {
      const track = checkbox.nextElementSibling;
      const thumb = track.firstElementChild;
      if (checkbox.checked) {
        track.classList.replace('bg-gray-300', 'bg-emerald-500');
        thumb.classList.replace('left-0.5', 'left-4');
      } else {
        track.classList.replace('bg-emerald-500', 'bg-gray-300');
        thumb.classList.replace('left-4', 'left-0.5');
      }
    }

    async function openRunModal() {
      document.getElementById('run-modal').classList.remove('hidden');
      document.getElementById('run-modal-msg').classList.add('hidden');
      document.getElementById('run-modal-submit').disabled = false;
      document.getElementById('run-modal-groups').innerHTML = '<span class="text-sm text-gray-400">Loading…</span>';
      setRunDateRange('24h');
      setRunProvider(_scheduleData?.scraping_provider || 'harvestapi');

      try {
        const res = await fetch('/api/groups');
        const data = await res.json();
        renderRunGroups(data.groups || []);
      } catch (e) {
        document.getElementById('run-modal-groups').innerHTML = '<span class="text-sm text-red-500">Failed to load roles.</span>';
      }
    }

    function closeRunModal() {
      document.getElementById('run-modal').classList.add('hidden');
    }

    async function submitRun() {
      const allToggles = document.querySelectorAll('.run-group-check');
      const groupStates = Array.from(allToggles).map(c => ({
        id: parseInt(c.value, 10),
        is_active: c.checked,
      }));

      const dateRange = _runDateRange;

      const submitBtn = document.getElementById('run-modal-submit');
      submitBtn.disabled = true;
      submitBtn.textContent = 'Starting…';

      try {
        // Save is_active states (syncs with settings page)
        await Promise.all(groupStates.map(({ id, is_active }) =>
          fetch('/api/groups/' + id, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ is_active }),
          })
        ));

        const res = await fetch('/api/run', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ dateRange, provider: _runProvider }),
        });
        const data = await res.json();

        closeRunModal();

        if (data.success) {
          if (typeof _runCallback === 'function') {
            _runCallback();
            _runCallback = null;
          } else {
            // Sidebar feedback
            const label = document.getElementById('sidebar-run-label');
            const sidebarBtn = document.getElementById('sidebar-run-btn');
            if (label) label.textContent = 'Running…';
            if (sidebarBtn) sidebarBtn.disabled = true;
            setTimeout(() => {
              if (label) label.textContent = 'Run Once';
              if (sidebarBtn) sidebarBtn.disabled = false;
            }, 5000);
          }
        } else {
          await showAlert(data.error || 'Failed to start pipeline.');
        }
      } catch (e) {
        closeRunModal();
        await showAlert('Network error. Could not reach the server.');
      }
    }

    // Restore schedule state on every page load (also populates _scheduleData for status modal)
    fetch('/api/schedule/status').then(r => r.json()).then(data => {
      _scheduleData = data;
      setScheduleUI(data.active, data.expression, data.timezone);
    }).catch(() => {});


    // Close modals on Escape
    document.addEventListener('keydown', e => {
      if (e.key === 'Escape') {
        closeScheduleModal();
        closeScheduleStatusModal();
        closeRunModal();
        closeVerdictDropdown();
        if (_jhConfirmResolve) _jhConfirmResolve(false);
        if (_jhAlertResolve) _jhAlertResolve();
      }
    });

    // ---- Clickable row helper ----
    function jobRowClick(event, url) {
      if (event.target.closest('.verdict-btn') || event.target.closest('a') || event.target.closest('button')) return;
      location.href = url;
    }

    // ---- Styled confirm / alert helpers ----
    let _jhConfirmResolve = null;
    function showConfirm(msg) {
      return new Promise(resolve => {
        _jhConfirmResolve = (v) => {
          document.getElementById('jh-confirm-modal').classList.add('hidden');
          resolve(v);
        };
        document.getElementById('jh-confirm-msg').textContent = msg;
        document.getElementById('jh-confirm-modal').classList.remove('hidden');
      });
    }

    let _jhAlertResolve = null;
    function showAlert(msg) {
      return new Promise(resolve => {
        _jhAlertResolve = () => {
          document.getElementById('jh-alert-modal').classList.add('hidden');
          resolve();
        };
        document.getElementById('jh-alert-msg').textContent = msg;
        document.getElementById('jh-alert-modal').classList.remove('hidden');
      });
    }

    // ---- Verdict dropdown ----
    let _verdictBtn = null;

    function openVerdictDropdown(btn) {
      _verdictBtn = btn;
      const dd = document.getElementById('verdict-dropdown');
      dd.classList.remove('hidden');
      const rect = btn.getBoundingClientRect();
      const ddW = 160;
      let left = rect.left;
      if (left + ddW > window.innerWidth - 8) left = window.innerWidth - ddW - 8;
      dd.style.top  = (rect.bottom + 4) + 'px';
      dd.style.left = left + 'px';
    }

    function closeVerdictDropdown() {
      document.getElementById('verdict-dropdown').classList.add('hidden');
      _verdictBtn = null;
    }

    document.addEventListener('click', e => {
      const dd = document.getElementById('verdict-dropdown');
      if (!dd.classList.contains('hidden') && !dd.contains(e.target) && !e.target.closest('.verdict-btn')) {
        closeVerdictDropdown();
      }
    });

    document.addEventListener('click', e => {
      const btn = e.target.closest('.verdict-btn');
      if (btn) { e.stopPropagation(); openVerdictDropdown(btn); }
    });

    function verdictChipHTML(verdict, style) {
      const detail = {
        STRONG_MATCH: '<span class="px-2 py-0.5 rounded-full text-xs font-medium bg-emerald-100 text-emerald-700 border border-emerald-200">STRONG MATCH ▾</span>',
        WEAK_MATCH:   '<span class="px-2 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-700 border border-yellow-200">WEAK MATCH ▾</span>',
        NO_MATCH:     '<span class="px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-600 border border-red-200">NO MATCH ▾</span>',
        DUPLICATE:    '<span class="px-2 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-600 border border-purple-200">DUPLICATE ▾</span>',
      };
      const compact = {
        STRONG_MATCH: '<span class="px-1.5 py-0.5 rounded text-xs font-medium bg-emerald-50 text-emerald-700 whitespace-nowrap">Strong ▾</span>',
        WEAK_MATCH:   '<span class="px-1.5 py-0.5 rounded text-xs font-medium bg-yellow-50 text-yellow-700 whitespace-nowrap">Weak ▾</span>',
        NO_MATCH:     '<span class="px-1.5 py-0.5 rounded text-xs font-medium bg-red-50 text-red-500 whitespace-nowrap">No match ▾</span>',
        DUPLICATE:    '<span class="px-1.5 py-0.5 rounded text-xs font-medium bg-purple-50 text-purple-600 whitespace-nowrap">Duplicate ▾</span>',
      };
      const full = {
        STRONG_MATCH: '<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-emerald-50 text-emerald-700 whitespace-nowrap">✅ Strong fit ▾</span>',
        WEAK_MATCH:   '<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-yellow-50 text-yellow-700 whitespace-nowrap">⚠️ Weak fit ▾</span>',
        NO_MATCH:     '<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-red-50 text-red-600 whitespace-nowrap">❌ No fit ▾</span>',
        DUPLICATE:    '<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-purple-50 text-purple-600 whitespace-nowrap">🔁 Duplicate ▾</span>',
      };
      const map = style === 'detail' ? detail : style === 'full' ? full : compact;
      return map[verdict] || verdict;
    }

    async function setVerdict(newVerdict) {
      const btn = _verdictBtn;
      if (!btn) return;
      const jobId  = btn.dataset.jobId;
      const current = btn.dataset.verdict;
      closeVerdictDropdown();
      if (newVerdict === current) return;
      const labels = { STRONG_MATCH: 'Strong fit', WEAK_MATCH: 'Weak fit', NO_MATCH: 'No fit', DUPLICATE: 'Duplicate' };
      const ok = await showConfirm('Change status to "' + (labels[newVerdict] || newVerdict) + '"?');
      if (!ok) return;
      try {
        const res = await fetch('/api/jobs/' + jobId + '/verdict', {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ verdict: newVerdict }),
        });
        const data = await res.json();
        if (data.success) {
          if (btn.dataset.chipStyle === 'detail') {
            location.reload();
          } else {
            btn.innerHTML = verdictChipHTML(newVerdict, btn.dataset.chipStyle || 'compact');
            btn.dataset.verdict = newVerdict;
          }
        } else {
          await showAlert(data.error || 'Failed to update status');
        }
      } catch (e) {
        await showAlert('Could not reach the server. Make sure the app is running and try again.');
      }
    }

    function openProfileSheet() {
      document.getElementById('profile-sheet').classList.remove('hidden');
    }
    function closeProfileSheet() {
      document.getElementById('profile-sheet').classList.add('hidden');
    }
  </script>
</body>
</html>
