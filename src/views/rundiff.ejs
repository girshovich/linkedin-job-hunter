<%
function fmtDate(iso) {
  if (!iso) return '—';
  const d = new Date(String(iso));
  if (isNaN(d.getTime())) return String(iso).slice(0, 16);
  const offset = 4 * 60;
  const local = new Date(d.getTime() + offset * 60_000);
  return local.toISOString().slice(0, 16).replace('T', ' ') + ' GMT+4';
}

function verdictChip(verdict) {
  if (verdict === 'STRONG_MATCH')
    return '<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-emerald-50 text-emerald-700 whitespace-nowrap">Strong fit</span>';
  if (verdict === 'WEAK_MATCH')
    return '<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-yellow-50 text-yellow-700 whitespace-nowrap">Weak fit</span>';
  if (verdict === 'NO_MATCH')
    return '<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-red-50 text-red-600 whitespace-nowrap">No fit</span>';
  if (verdict === 'DUPLICATE')
    return '<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-purple-50 text-purple-600 whitespace-nowrap">Duplicate</span>';
  if (verdict === 'BLACKLISTED')
    return '<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600 whitespace-nowrap">Blacklisted</span>';
  if (verdict === 'FILTERED')
    return '<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-slate-100 text-slate-500 whitespace-nowrap">Filtered</span>';
  return '';
}

function scoreColor(score) {
  if (score == null) return 'text-gray-300';
  if (score >= 71) return 'text-emerald-600 font-semibold';
  if (score >= 51) return 'text-yellow-600 font-semibold';
  return 'text-red-500';
}
%>

<div class="mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Run Diff</h1>
  <p class="text-sm text-gray-500 mt-1">Comparing the last 2 pipeline runs</p>
</div>

<% if (error) { %>
<div class="bg-red-50 border border-red-200 rounded-xl px-5 py-4 text-sm text-red-700"><%= error %></div>
<% } else { %>

<!-- Run summary -->
<div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-6">
  <div class="bg-white border border-gray-200 rounded-xl px-5 py-4">
    <p class="text-xs text-gray-400 uppercase tracking-wide font-medium mb-1">Newer run #<%= runNewer.id %></p>
    <p class="text-sm font-semibold text-gray-900"><%= fmtDate(runNewer.ran_at) %></p>
    <% if (runNewer.scraping_provider) { %><p class="text-xs text-gray-400 mt-0.5"><%= runNewer.scraping_provider %></p><% } %>
    <p class="text-xs text-gray-500 mt-1"><%= onlyInNewer.length + inBoth.length %> unique jobs logged</p>
  </div>
  <div class="bg-white border border-gray-200 rounded-xl px-5 py-4">
    <p class="text-xs text-gray-400 uppercase tracking-wide font-medium mb-1">Older run #<%= runOlder.id %></p>
    <p class="text-sm font-semibold text-gray-900"><%= fmtDate(runOlder.ran_at) %></p>
    <% if (runOlder.scraping_provider) { %><p class="text-xs text-gray-400 mt-0.5"><%= runOlder.scraping_provider %></p><% } %>
    <p class="text-xs text-gray-500 mt-1"><%= onlyInOlder.length + inBoth.length %> unique jobs logged</p>
  </div>
</div>

<div class="space-y-3">

<!-- New this run -->
<details class="group bg-white rounded-xl border border-blue-200 shadow-sm overflow-hidden">
  <summary class="flex items-center justify-between px-5 py-4 cursor-pointer select-none list-none hover:bg-blue-50/50 transition-colors">
    <div class="flex items-center gap-3">
      <svg class="w-4 h-4 text-gray-400 flex-shrink-0 transition-transform group-open:rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
      <span class="font-semibold text-gray-900 text-sm">Only in new run</span>
      <span class="text-xs text-blue-600 bg-blue-50 px-2 py-0.5 rounded-full font-medium"><%= onlyInNewer.length %></span>
    </div>
    <span class="text-xs text-gray-400 whitespace-nowrap">run #<%= runNewer.id %></span>
  </summary>
  <div class="border-t border-gray-100">
    <%- jobTable(onlyInNewer) %>
  </div>
</details>

<!-- Seen in both -->
<details class="group bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
  <summary class="flex items-center justify-between px-5 py-4 cursor-pointer select-none list-none hover:bg-gray-50 transition-colors">
    <div class="flex items-center gap-3">
      <svg class="w-4 h-4 text-gray-400 flex-shrink-0 transition-transform group-open:rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
      <span class="font-semibold text-gray-900 text-sm whitespace-nowrap">Seen in both</span>
      <span class="text-xs text-gray-500 bg-gray-100 px-2 py-0.5 rounded-full font-medium"><%= inBoth.length %></span>
    </div>
    <span class="text-xs text-gray-400 whitespace-nowrap">verdict from run #<%= runOlder.id %></span>
  </summary>
  <div class="border-t border-gray-100">
    <%- jobTable(inBoth) %>
  </div>
</details>

<!-- Only in previous run -->
<details class="group bg-white rounded-xl border border-orange-200 shadow-sm overflow-hidden">
  <summary class="flex items-center justify-between px-5 py-4 cursor-pointer select-none list-none hover:bg-orange-50/50 transition-colors">
    <div class="flex items-center gap-3">
      <svg class="w-4 h-4 text-gray-400 flex-shrink-0 transition-transform group-open:rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
      <span class="font-semibold text-gray-900 text-sm">Only in previous run</span>
      <span class="text-xs text-orange-600 bg-orange-50 px-2 py-0.5 rounded-full font-medium"><%= onlyInOlder.length %></span>
    </div>
    <span class="text-xs text-gray-400 whitespace-nowrap">run #<%= runOlder.id %></span>
  </summary>
  <div class="border-t border-gray-100">
    <%- jobTable(onlyInOlder) %>
  </div>
</details>

</div>
<% } %>

<%
function jobTable(jobs) {
  if (jobs.length === 0) {
    return '<p class="px-5 py-6 text-sm text-gray-400 text-center">No jobs.</p>';
  }

  // Desktop table rows
  let desktopRows = jobs.map(job => {
    const scoreCell = `<td class="py-2.5 px-1 w-0 whitespace-nowrap text-right" style="min-width:2.25rem;">${job.ai_score != null ? `<span class="text-xs ${scoreColor(job.ai_score)}">${job.ai_score}</span>` : ''}</td>`;
    const link = job.url
      ? `<a href="${job.url}" target="_blank" rel="noopener noreferrer" class="text-blue-500 hover:underline text-xs">link</a>`
      : '<span class="text-gray-300 text-xs">—</span>';
    const loc = job.location ? `<span class="text-xs text-gray-400 truncate max-w-[180px] block">${job.location}</span>` : '';
    const titleHtml = job.internal_job_id
      ? `<a href="/job/${job.internal_job_id}" class="hover:text-blue-600 transition-colors block">${job.title}</a>`
      : `<span class="block">${job.title}</span>`;
    const chip = `<span onclick="showJobMenu(event,this)" data-internal-id="${job.internal_job_id || ''}" data-url="${job.url || ''}" data-log-id="${job.id}" data-verdict="${job.ai_verdict}" class="cursor-pointer">${verdictChip(job.ai_verdict)}</span>`;
    return `<tr class="hover:bg-gray-50 transition-colors">
      <td class="px-5 py-2.5 text-sm text-gray-700 font-medium whitespace-nowrap w-0 max-w-[200px] truncate">${job.company}</td>
      <td class="px-3 py-2.5 text-sm text-gray-900">
        ${titleHtml}
        ${loc}
      </td>
      <td class="pl-3 py-2.5 w-0 whitespace-nowrap text-right">${chip}</td>
      ${scoreCell}
      <td class="pl-2 pr-5 py-2.5 w-0 whitespace-nowrap">${link}</td>
    </tr>`;
  }).join('');

  // Mobile cards
  let mobileCards = jobs.map(job => {
    const target = job.internal_job_id ? `/job/${job.internal_job_id}` : (job.url || null);
    const chip = `<span onclick="showJobMenu(event,this)" data-internal-id="${job.internal_job_id || ''}" data-url="${job.url || ''}" data-log-id="${job.id}" data-verdict="${job.ai_verdict}" class="cursor-pointer">${verdictChip(job.ai_verdict)}</span>`;
    const scoreSpan = `<span class="text-xs text-right" style="min-width:1.75rem;display:inline-block;">${job.ai_score != null ? `<span class="${scoreColor(job.ai_score)}">${job.ai_score}</span>` : ''}</span>`;
    const locHtml = job.location ? `<p class="text-xs text-gray-400 truncate mt-0.5">${job.location}</p>` : '';
    return `<div class="px-4 py-3 hover:bg-gray-50 transition-colors${target ? ' cursor-pointer' : ''}"${target ? ` onclick="location.href='${target}'"` : ''}>
      <div class="flex items-center justify-between gap-2 mb-0.5">
        <span class="text-sm font-medium text-gray-700 truncate">${job.company}</span>
        <div class="flex items-center gap-1.5 flex-shrink-0">${chip}${scoreSpan}</div>
      </div>
      <p class="text-xs text-gray-500 truncate">${job.title}</p>
      ${locHtml}
    </div>`;
  }).join('');

  return `<table class="hidden md:table w-full"><tbody class="divide-y divide-gray-50">${desktopRows}</tbody></table><div class="md:hidden divide-y divide-gray-50">${mobileCards}</div>`;
}
%>

<!-- Job context menu -->
<div id="job-menu" class="hidden fixed z-50 bg-white border border-gray-200 rounded-xl shadow-lg p-1.5 text-xs min-w-[160px]">
  <a id="job-menu-view" href="#" class="flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-gray-50 text-gray-700 transition-colors">View details</a>
  <a id="job-menu-link" href="#" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-gray-50 text-gray-700 transition-colors">Open on LinkedIn</a>
  <div class="mt-1 pt-1 border-t border-gray-100">
    <p class="px-3 py-1 text-xs font-medium text-gray-400">Change verdict</p>
    <button onclick="menuSetVerdict('STRONG_MATCH')" class="flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-emerald-50 text-emerald-700 w-full text-left transition-colors">✅ Strong fit</button>
    <button onclick="menuSetVerdict('WEAK_MATCH')"   class="flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-yellow-50 text-yellow-700 w-full text-left transition-colors">⚠️ Weak fit</button>
    <button onclick="menuSetVerdict('NO_MATCH')"     class="flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-red-50 text-red-600 w-full text-left transition-colors">❌ No fit</button>
  </div>
</div>

<script>
let _menuTargetEl = null;

function showJobMenu(event, el) {
  event.stopPropagation();
  _menuTargetEl = el;
  const internalId = el.dataset.internalId;
  const url = el.dataset.url;
  const menu = document.getElementById('job-menu');
  const viewLink = document.getElementById('job-menu-view');
  const extLink = document.getElementById('job-menu-link');

  if (internalId) {
    viewLink.href = '/job/' + internalId;
    viewLink.classList.remove('hidden');
  } else {
    viewLink.classList.add('hidden');
  }
  if (url) {
    extLink.href = url;
    extLink.classList.remove('hidden');
  } else {
    extLink.classList.add('hidden');
  }

  const rect = el.getBoundingClientRect();
  menu.style.top = (rect.bottom + 4) + 'px';
  menu.style.left = Math.min(rect.left, window.innerWidth - 172) + 'px';
  menu.classList.remove('hidden');
}

function verdictChipStatic(verdict) {
  if (verdict === 'STRONG_MATCH') return '<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-emerald-50 text-emerald-700 whitespace-nowrap">Strong fit</span>';
  if (verdict === 'WEAK_MATCH')   return '<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-yellow-50 text-yellow-700 whitespace-nowrap">Weak fit</span>';
  if (verdict === 'NO_MATCH')     return '<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-red-50 text-red-600 whitespace-nowrap">No fit</span>';
  if (verdict === 'DUPLICATE')    return '<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-purple-50 text-purple-600 whitespace-nowrap">Duplicate</span>';
  if (verdict === 'BLACKLISTED')  return '<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600 whitespace-nowrap">Blacklisted</span>';
  if (verdict === 'FILTERED')     return '<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-slate-100 text-slate-500 whitespace-nowrap">Filtered</span>';
  return verdict;
}

async function menuSetVerdict(newVerdict) {
  const el = _menuTargetEl;
  if (!el) return;
  document.getElementById('job-menu').classList.add('hidden');

  const current = el.dataset.verdict;
  if (newVerdict === current) return;

  const labels = { STRONG_MATCH: 'Strong fit', WEAK_MATCH: 'Weak fit', NO_MATCH: 'No fit' };
  if (!confirm('Change verdict to "' + (labels[newVerdict] || newVerdict) + '"?')) return;

  const internalId = el.dataset.internalId;
  const logId = el.dataset.logId;
  const endpoint = internalId
    ? '/api/jobs/' + internalId + '/verdict'
    : '/api/run-log/' + logId + '/verdict';

  try {
    const res = await fetch(endpoint, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ verdict: newVerdict }),
    });
    const data = await res.json();
    if (data.success) {
      el.dataset.verdict = newVerdict;
      if (data.internal_job_id && !internalId) {
        el.dataset.internalId = String(data.internal_job_id);
        document.getElementById('job-menu-view').href = '/job/' + data.internal_job_id;
      }
      el.innerHTML = verdictChipStatic(newVerdict);
    } else {
      alert(data.error || 'Failed to update verdict');
    }
  } catch (e) {
    alert('Could not reach the server.');
  }
}

document.addEventListener('click', () => {
  document.getElementById('job-menu').classList.add('hidden');
});
</script>
